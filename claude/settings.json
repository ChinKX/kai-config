{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "SHELL": "/bin/zsh"
  },
  "permissions": {
    "allow": [
      "WebFetch",
      "WebSearch",
      "Bash(gh pr checks:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr create:*)",
      "Bash(gh api:*)",
      "Bash(gh repo:*)",
      "Bash(gh --version)",
      "Bash(mkdir:*)",
      "Bash(find:*)",
      "Bash(cat:*)",
      "Bash(tree:*)",
      "Bash(sed:*)",
      "Bash(source:*)",
      "Bash(node:*)",
      "Bash(npx:*)",
      "Bash(npx tsc:*)",
      "Bash(npm i:*)",
      "Bash(npm view:*)",
      "Bash(npm run compile:*)",
      "Bash(npm run lint:*)",
      "Bash(npm run lint:eslint:*)",
      "Bash(npm run lint:prettier:*)",
      "Bash(npm run lint:prettier:fix:*)",
      "Bash(npm run lint:fix:*)",
      "Bash(python3:*)",
      "Bash(pyftsubset:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git checkout:*)",
      "Bash(git reset:*)",
      "Bash(git cherry-pick:*)",
      "mcp__context7__resolve-library-id",
      "mcp__context7__get-library-docs",
      "mcp__context7__query-docs",
      "mcp__sentry__search_events",
      "mcp__sentry__search_issues",
      "mcp__sentry__search_issue_events",
      "mcp__sentry__get_issue_details",
      "mcp__sentry__get_issue_tag_values",
      "mcp__sentry__find_organizations",
      "mcp__claude_ai_Excalidraw__read_me",
      "mcp__claude_ai_Excalidraw__create_view",
      "mcp__plugin_figma_figma__get_design_context",
      "mcp__claude_ai_Figma__get_design_context",
      "mcp__claude_ai_Figma__get_screenshot",
      "mcp__pencil",
      "mcp__argent"
    ],
    "deny": [],
    "defaultMode": "auto"
  },
  "enabledPlugins": {
    "andrej-karpathy-skills@karpathy-skills": true,
    "chrome-devtools-mcp@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "figma@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true,
    "understand-anything@understand-anything": true,
    "sentry@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "claude-plugins-official": {
      "source": {
        "source": "git",
        "url": "git@github.com:anthropics/claude-plugins-official.git"
      }
    },
    "karpathy-skills": {
      "source": {
        "source": "github",
        "repo": "forrestchang/andrej-karpathy-skills"
      }
    },
    "understand-anything": {
      "source": {
        "source": "github",
        "repo": "Lum1104/Understand-Anything"
      }
    }
  },
  "skipWebFetchPreflight": true,
  "alwaysThinkingEnabled": true,
  "effortLevel": "xhigh",
  "skipWorkflowUsageWarning": true,
  "theme": "light",
  "tui": "fullscreen"
}
