#!/usr/bin/env bash
# Pre-commit leak gate for kai-config (a PUBLIC repo).
# Blocks commits whose staged files contain secrets, tokens, or hardcoded home paths.
# Enable on a machine with:  git config core.hooksPath .githooks
# Override a false positive with:  git commit --no-verify
set -euo pipefail

pattern='BEGIN [A-Z ]*PRIVATE KEY|xox[baprs]-|gh[pousr]_[A-Za-z0-9]{20,}|AKIA[0-9A-Z]{16}|sk-ant-[A-Za-z0-9_-]{20,}|sk-[A-Za-z0-9]{20,}|AIza[0-9A-Za-z_-]{35}|eyJ[A-Za-z0-9_-]{20,}\.[A-Za-z0-9_-]{10,}|npm_[A-Za-z0-9]{36}|/Users/[A-Za-z0-9._-]+/|/home/[A-Za-z0-9._-]+/'
hits=0

while IFS= read -r f; do
  [ -z "$f" ] && continue
  case "$f" in .githooks/*) continue ;; esac   # never scan the gate itself
  # Scan the staged blob, not the working-tree file: the commit is built from the
  # index, and the two can diverge (git add -p, edit-after-stage, rm-after-stage).
  if matches=$(git show ":$f" | grep -nIEi "$pattern"); then
    echo "🚫 leak-gate: internal/confidential marker in staged file: $f"
    printf '%s\n' "$matches" | sed 's/^/     /'
    hits=1
  fi
done < <(git diff --cached --name-only --diff-filter=ACM)

if [ "$hits" -ne 0 ]; then
  echo ""
  echo "Commit blocked. Move the content to an untracked/local file, or bypass with: git commit --no-verify"
  exit 1
fi
